{
  "name": "lituus-bot",
  "version": "0.1.0",
  "description": "A Discord Stage recorder bot that stores per-speaker Ogg segments and Deepgram transcripts.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "api:dev": "tsx watch src/api/index.ts",
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "start": "node dist/index.js",
    "api:start": "node dist/api/index.js",
    "commands:register": "tsx src/discord/register-commands.ts"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7",
    "hono": "^4.12.23",
    "node-crc": "1.3.2",
    "prism-media": "2.0.0-alpha.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
